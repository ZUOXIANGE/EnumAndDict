{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=EnumDictDemo.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "DictTranslate": {
    "MaxRecursionDepth": 10,
    "EnableBatchTranslation": true,
    "CacheDurationMinutes": 60,
    "ThrowOnMissingTargetProperty": false,
    "EnableCycleDetection": true
  }
}